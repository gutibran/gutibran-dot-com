---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css"

const { pageTitle, description } = Astro.props;
---

<html lang="en" class="min-h-screen">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description}>
		<title>{pageTitle} | Brandon Gutierrez's Website</title>
	</head>
	<body class="min-h-screen flex flex-col gap-9 justify-center align-middle my-3 md:w-[768px] md:my-0 md:mx-auto">
        <Header />
        <main class="flex-1 flex flex-col gap-6 mx-3">
            <slot />
        </main>
        <Footer />
	</body>
</html>